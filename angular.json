{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "taro-debugger-frontend": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/taro-debugger-frontend",
      "sourceRoot": "projects/taro-debugger-frontend/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/taro-debugger-frontend/src/main.ts",
            "tsConfig": "projects/taro-debugger-frontend/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/taro-debugger-frontend/public"
              },
              "projects/taro-debugger-frontend/src/assets",
              {
                "glob": "**/*",
                "input": "node_modules/monaco-editor/min/vs",
                "output": "/assets/monaco/"
              }
            ],
            "styles": [
              "projects/taro-debugger-frontend/src/material-theme.scss",
              "projects/taro-debugger-frontend/src/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "taro-debugger-frontend:build:production"
            },
            "development": {
              "buildTarget": "taro-debugger-frontend:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
