{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "taro-debugger-frontend": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/taro-debugger-frontend",
      "sourceRoot": "projects/taro-debugger-frontend/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/taro-debugger-frontend",
            "browser": "projects/taro-debugger-frontend/src/main.ts",
            "tsConfig": "projects/taro-debugger-frontend/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/taro-debugger-frontend/public"
              },
              {
                "glob": "**/*",
                "input": "node_modules/monaco-editor/min/vs",
                "output": "/assets/monaco/"
              }
            ],
            "styles": [
              "projects/taro-debugger-frontend/src/material-theme.scss",
              "projects/taro-debugger-frontend/src/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1MB",
                  "maximumError": "2MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10kB",
                  "maximumError": "16kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "taro-debugger-frontend:build:production"
            },
            "development": {
              "buildTarget": "taro-debugger-frontend:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/taro-debugger-frontend/tsconfig.spec.json"
          }
        }
      }
    },
    "dap-core": {
      "projectType": "library",
      "root": "projects/dap-core",
      "sourceRoot": "projects/dap-core/src",
      "prefix": "taro",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/dap-core/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/dap-core/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/dap-core/tsconfig.spec.json"
          }
        }
      }
    },
    "ui-console": {
      "projectType": "library",
      "root": "projects/ui-console",
      "sourceRoot": "projects/ui-console/src",
      "prefix": "taro",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/ui-console/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ui-console/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/ui-console/tsconfig.spec.json"
          }
        }
      }
    },
    "ui-editor": {
      "projectType": "library",
      "root": "projects/ui-editor",
      "sourceRoot": "projects/ui-editor/src",
      "prefix": "taro",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/ui-editor/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ui-editor/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/ui-editor/tsconfig.spec.json"
          }
        }
      }
    }
  }
}
