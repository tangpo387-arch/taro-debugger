{
  "name": "taro-debugger-frontend",
  "version": "1.0.0-dev",
  "author": "Tang Po <tangpo387@gmail.com>",
  "main": "dist/electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build taro-debugger-frontend",
    "build:dap-core": "ng build dap-core",
    "build:ui-console": "ng build ui-console",
    "watch": "ng build --watch --configuration development taro-debugger-frontend",
    "test": "ng test taro-debugger-frontend --watch=false && ng test ui-console --watch=false && ng test ui-editor --watch=false && ng test dap-core --watch=false",
    "postinstall": "node scripts/postinstall.js",
    "electron:build": "tsc -p tsconfig.electron.json",
    "electron:run": "electron . --no-sandbox",
    "electron:dev": "npm run electron:build && electron . --no-sandbox",
    "electron:start": "ng build && npm run electron:build && electron . --no-sandbox",
    "electron:package": "ng build && npm run electron:build && electron-builder -lw",
    "lint:docs": "node scripts/doc-guard.js verify"
  },
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/cdk": "~21.2.1",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.7",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "monaco-editor": "^0.55.1",
    "ngx-monaco-editor-v2": "^21.1.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  },
  "build": {
    "appId": "com.taro.debugger",
    "productName": "Taro Debugger",
    "directories": {
      "output": "dist/release"
    },
    "files": [
      "dist/electron/**/*",
      "dist/taro-debugger-frontend/browser/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "win": {
      "target": "nsis"
    }
  }
}